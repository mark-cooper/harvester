# Local defaults, also used by docker compose env_file.
DATA_DIR=data
DATABASE_URL=postgres://admin:admin@localhost:5432/harvester
DATABASE_URL_DOCKER=postgres://admin:admin@postgres:5432/harvester
METADATA_PREFIX=oai_ead
PGRST_DB_ANON_ROLE=harvester_reader
PGRST_DB_SCHEMAS=public
PGRST_DB_URI=postgres://admin:admin@localhost:5432/harvester
PGRST_DB_URI_DOCKER=postgres://admin:admin@postgres:5432/harvester
PGRST_OPENAPI_MODE=disabled
RULES_FILE_DOCKER=/app/rules/default.txt
SQLX_OFFLINE=true
